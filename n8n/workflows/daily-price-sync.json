    {
      "id": "a38b68e5-94fb-42cc-88ce-8a09df834293",
      "name": "Merge branches",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [1120, 464],
      "parameters": {"mode": "append", "numberInputs": 4}
    },
    {
      "id": "d5760fd8-94ea-45c0-8195-0afb3dba59cd",
      "name": "Pack products",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1344, 496],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst sourceName = $('Split by source').item.json.name;\nconst productos = items.map(i => i.json).filter(p => p && p.descripcion);\nreturn [{ json: { source_name: sourceName, productos, count: productos.length } }];"
      }
    },
    {
      "id": "cb38f1d6-e27b-4ba6-8e0d-6b44d7d8786b",
      "name": "DELETE old rows (Supabase)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1568, 496],
      "parameters": {
        "method": "DELETE",
        "url": "={{ $env.SUPABASE_URL }}/productos",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{"name": "fuente", "value": "=eq.{{ $('Pack products').item.json.source_name }}"}]
