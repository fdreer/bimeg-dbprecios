      "name": "GET /productos",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [896, 0],
      "parameters": {
        "url": "={{ $env.SUPABASE_URL }}/productos?order=fuente.asc,descripcion.asc",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "apikey",        "value": "={{ $env.SUPABASE_ANON_KEY }}"},
