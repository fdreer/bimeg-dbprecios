      "position": [1344, 0],
      "parameters": {
        "resource": "message",
        "operation": "send",
        "sendTo": "={{ $env.REPORT_EMAIL_TO }}",
        "subject": "=Precios BIMEG — {{ $now.format('dd/MM/yyyy') }}",
        "emailType": "text",
        "message": "Adjunto el reporte de precios del día.",
        "options": {
          "attachmentsUi": { "attachmentsBinary": [{ "property": "data" }] },
          "senderName": "BIMEG Precios"
        }
      }
    },
