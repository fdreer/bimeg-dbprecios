        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"source_name\": \"{{ $json.name }}\"\n}",
        "options": {}
      },
      "id": "a1b2c3d4-000d-4000-8000-00000000000d",
      "name": "POST /scrape/sitemap",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1160, 780]
    },
    {
      "parameters": {
        "numberInputs": 4
      },
      "id": "a1b2c3d4-0008-4000-8000-000000000008",
      "name": "Merge branches",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [1380, 420]
    },
    {
      "parameters": {
        "jsCode": "// Agrupa todos los productos de esta iteración en un único array\n// y los adjunta al nombre de la fuente (tomado del Split by source).\n//\n// OUTPUT único: { source_name, productos: [...] }\n// Esto es lo que consumen los dos nodos siguientes (DELETE y POST a Supabase).\n\nconst items = $input.all();\nconst sourceName = $('Split by source').item.json.name;\n\nconst productos = items.map(i => i.json).filter(p => p && p.descripcion);\n\nreturn [\n  {\n    json: {\n      source_name: sourceName,\n      productos,\n      count: productos.length\n    }\n  }\n];"
      },
      "id": "a1b2c3d4-0009-4000-8000-000000000009",
      "name": "Pack products",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1600, 420]
    },
    {
      "parameters": {
        "method": "DELETE",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/productos",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "fuente",
              "value": "=eq.{{ $json.source_name }}"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_ANON_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_ANON_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-000a-4000-8000-00000000000a",
      "name": "DELETE old rows (Supabase)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1820, 420]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/productos",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.productos) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_ANON_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_ANON_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "a1b2c3d4-000b-4000-8000-00000000000b",
      "name": "INSERT new rows (Supabase)",
