    {
      "parameters": {
        "jsCode": "// TODO: implementar consumo de fuentes tipo 'api' (endpoint + field_mappings)\n// Por ahora devuelve array vacío para que el pipeline no falle.\n// Los datos de la fuente están en $input.first().json — incluye endpoint, auth_header, auth_value, field_mappings, etc.\nreturn [];"
      },
