    {
      "id": "acfdece6-2e63-4ec8-8edf-8f297a720008",
      "name": "Format for Excel",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 0],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst formatted = items.map(item => {\n  const r = item.json || {};\n  return {\n    \"Empresa\":              r.empresa              ?? \"\",\n    \"Código Producto\":      r.codigo_producto      ?? \"\",\n    \"Descripción\":          r.descripcion          ?? \"\",\n    \"Marca\":                r.marca                ?? \"\",\n    \"Tipo de Producto\":     r.tipo_producto        ?? \"\",\n    \"Familia\":              r.familia_producto     ?? \"\",\n    \"Subtipo\":              r.subtipo_producto     ?? \"\",\n    \"Categoría\":            r.categoria            ?? \"\",\n    \"Jerarquía Completa\":   r.categoria_completa   ?? \"\",\n    \"Precio\":               r.precio               ?? null,\n    \"Precio Lista\":         r.precio_lista         ?? null,\n    \"Precio sin Impuestos\": r.precio_sin_impuestos ?? null,\n    \"Disponibilidad\":       r.disponibilidad       ?? \"\",\n    \"Unidad\":               r.unidad_medida        ?? \"\",\n    \"Multiplicador\":        r.multiplicador_unidad ?? null,\n    \"URL Producto\":         r.url_producto         ?? \"\",\n  };\n});\nreturn formatted.map(json => ({ json }));"
      }
    },
    {
      "id": "09d125d1-805b-466b-8ec7-573b56206a5f",
      "name": "Generate Excel",
      "type": "n8n-nodes-base.convertToFile",
      "typeVersion": 1.1,
      "position": [1344, 0],
      "parameters": {
        "operation": "xlsx",
        "options": {"fileName": "=precios-{{ $now.format('yyyy-MM-dd') }}.xlsx"}
      }
    },
    {
      "id": "7691f9f4-6cfb-433b-994c-b3af16f06af8",
      "name": "Compress Excel",
      "type": "n8n-nodes-base.compression",
      "typeVersion": 1.1,
      "position": [1568, 0],
      "parameters": {
        "operation": "compress",
        "outputFormat": "zip",
        "fileName": "=precios-{{ $now.format('yyyy-MM-dd') }}.zip"
      }
    },
    {
      "id": "3d7167d3-1da5-4dcb-ac35-03b7df7ca55b",
      "name": "Send Report Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1792, 0],
